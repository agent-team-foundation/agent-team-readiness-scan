{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/agent-team-foundation/agent-team-readiness-scan/schemas/atr-1.schema.json",
  "title": "Agent Team Readiness report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "wedge",
    "generated_at",
    "repository",
    "scope",
    "headline_score",
    "dimensions",
    "top_3_fixes",
    "artifacts",
    "summary"
  ],
  "properties": {
    "schema_version": { "const": "atr-1" },
    "wedge": { "const": "agent-team-readiness" },
    "generated_at": {
      "type": "string",
      "pattern": "^(?:(?:\\d{4})-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|02-(?:0[1-9]|1\\d|2[0-8]))|(?:\\d{2}(?:0[48]|[2468][048]|[13579][26])|(?:00|0[48]|[2468][048]|[13579][26])00)-02-29)T(?:[01]\\d|2[0-3]):[0-5]\\d:[0-5]\\d(?:\\.\\d{1,9})?Z$"
    },
    "repository": { "$ref": "#/$defs/repository" },
    "scope": { "$ref": "#/$defs/scope" },
    "headline_score": {
      "description": "Weighted repo-level score. Null only when evidence coverage is insufficient.",
      "type": ["integer", "null"],
      "minimum": 0,
      "maximum": 100
    },
    "dimensions": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "prefixItems": [
        { "$ref": "#/$defs/instructionDimension" },
        { "$ref": "#/$defs/isolationDimension" },
        { "$ref": "#/$defs/ownershipDimension" },
        { "$ref": "#/$defs/contextDimension" },
        { "$ref": "#/$defs/verificationDimension" },
        { "$ref": "#/$defs/handoffDimension" }
      ],
      "items": false
    },
    "top_3_fixes": {
      "type": "array",
      "maxItems": 3,
      "items": { "$ref": "#/$defs/topFix" }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence", "agents_draft", "context_tree_seed_map"],
      "properties": {
        "evidence": { "const": "evidence.json" },
        "agents_draft": { "const": "AGENTS.draft.md" },
        "context_tree_seed_map": { "const": "context-tree-seed-map.md" }
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "name",
        "revision",
        "worktree_state",
        "file_count",
        "analyzed_file_count",
        "skipped_file_count",
        "inventory_truncated"
      ],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "revision": { "type": ["string", "null"] },
        "worktree_state": { "enum": ["clean", "dirty", "not-git", "unknown"] },
        "file_count": { "type": "integer", "minimum": 0 },
        "analyzed_file_count": { "type": "integer", "minimum": 0 },
        "skipped_file_count": { "type": "integer", "minimum": 0 },
        "inventory_truncated": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": { "properties": { "worktree_state": { "enum": ["dirty", "not-git", "unknown"] } }, "required": ["worktree_state"] },
          "then": { "properties": { "revision": { "type": "null" } } }
        }
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim", "observable_only", "evidence_coverage", "limitations"],
      "properties": {
        "claim": { "const": "repo-level readiness" },
        "observable_only": { "const": true },
        "evidence_coverage": { "type": "integer", "minimum": 0, "maximum": 100 },
        "limitations": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "evidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path", "line", "command", "detail"],
      "properties": {
        "kind": { "enum": ["file", "missing", "command"] },
        "path": { "type": ["string", "null"] },
        "line": { "type": ["integer", "null"], "minimum": 1 },
        "command": { "type": ["string", "null"], "maxLength": 240 },
        "detail": { "type": "string", "minLength": 1, "maxLength": 240 }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "command" } }, "required": ["kind"] },
          "then": { "properties": { "command": { "type": "string", "minLength": 1, "maxLength": 240 } } }
        },
        {
          "if": { "properties": { "kind": { "enum": ["file", "missing"] } }, "required": ["kind"] },
          "then": {
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "command": { "type": "null" }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "missing" } }, "required": ["kind"] },
          "then": { "properties": { "line": { "type": "null" } } }
        }
      ]
    },
    "blocker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "dimension",
        "severity",
        "title",
        "evidence",
        "why_it_matters",
        "minimum_fix",
        "first_verification_step"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "dimension": { "$ref": "#/$defs/dimensionKey" },
        "severity": { "enum": ["critical", "high", "medium"] },
        "title": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidenceRef" }
        },
        "why_it_matters": { "type": "string", "minLength": 1 },
        "minimum_fix": { "type": "string", "minLength": 1 },
        "first_verification_step": { "type": "string", "minLength": 1 }
      }
    },
    "dimensionKey": {
      "enum": [
        "instruction_convergence",
        "task_workspace_isolation",
        "ownership_boundaries",
        "shared_decision_context",
        "repeatable_verification",
        "handoff_definition"
      ]
    },
    "dimension": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "name",
        "weight",
        "score",
        "status",
        "evidence_status",
        "rationale",
        "strongest_evidence",
        "must_fix_blocker",
        "minimum_improvement",
        "unknowns"
      ],
      "properties": {
        "key": { "$ref": "#/$defs/dimensionKey" },
        "name": { "type": "string", "minLength": 1 },
        "weight": { "type": "integer", "minimum": 1, "maximum": 100 },
        "score": { "type": "integer", "minimum": 0, "maximum": 10 },
        "status": { "enum": ["strong", "developing", "constrained"] },
        "evidence_status": { "enum": ["observed", "partial"] },
        "rationale": { "type": "string", "minLength": 1 },
        "strongest_evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidenceRef" }
        },
        "must_fix_blocker": {
          "oneOf": [
            { "$ref": "#/$defs/blocker" },
            { "type": "null" }
          ]
        },
        "minimum_improvement": { "type": "string", "minLength": 1 },
        "unknowns": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "score": { "type": "integer", "minimum": 8 } }, "required": ["score"] },
          "then": { "properties": { "status": { "const": "strong" } } }
        },
        {
          "if": { "properties": { "score": { "type": "integer", "minimum": 5, "maximum": 7 } }, "required": ["score"] },
          "then": { "properties": { "status": { "const": "developing" } } }
        },
        {
          "if": { "properties": { "score": { "type": "integer", "maximum": 4 } }, "required": ["score"] },
          "then": { "properties": { "status": { "const": "constrained" } } }
        }
      ]
    },
    "instructionDimension": {
      "allOf": [
        { "$ref": "#/$defs/dimension" },
        { "type": "object", "properties": { "key": { "const": "instruction_convergence" }, "name": { "const": "Instruction convergence" }, "weight": { "const": 18 } } }
      ]
    },
    "isolationDimension": {
      "allOf": [
        { "$ref": "#/$defs/dimension" },
        { "type": "object", "properties": { "key": { "const": "task_workspace_isolation" }, "name": { "const": "Task and workspace isolation" }, "weight": { "const": 18 } } }
      ]
    },
    "ownershipDimension": {
      "allOf": [
        { "$ref": "#/$defs/dimension" },
        { "type": "object", "properties": { "key": { "const": "ownership_boundaries" }, "name": { "const": "Code and domain ownership" }, "weight": { "const": 16 } } }
      ]
    },
    "contextDimension": {
      "allOf": [
        { "$ref": "#/$defs/dimension" },
        { "type": "object", "properties": { "key": { "const": "shared_decision_context" }, "name": { "const": "Shared decisions and context" }, "weight": { "const": 16 } } }
      ]
    },
    "verificationDimension": {
      "allOf": [
        { "$ref": "#/$defs/dimension" },
        { "type": "object", "properties": { "key": { "const": "repeatable_verification" }, "name": { "const": "Repeatable verification" }, "weight": { "const": 20 } } }
      ]
    },
    "handoffDimension": {
      "allOf": [
        { "$ref": "#/$defs/dimension" },
        { "type": "object", "properties": { "key": { "const": "handoff_definition" }, "name": { "const": "Handoff and definition of done" }, "weight": { "const": 12 } } }
      ]
    },
    "topFix": { "$ref": "#/$defs/blocker" }
  }
}
